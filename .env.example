# Supabase Configuration
# Get these values from your Supabase project dashboard at https://app.supabase.com/

# Your Supabase project ID (found in project settings)
VITE_SUPABASE_PROJECT_ID="your_project_id_here"

# Your Supabase project URL (format: https://your-project-id.supabase.co)
VITE_SUPABASE_URL="https://your_project_id_here.supabase.co"

# Your Supabase publishable/anon key (safe to use in client-side code)
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key_here"

# Your Supabase anon key (typically the same as publishable key)
VITE_SUPABASE_ANON_KEY="your_anon_key_here"
